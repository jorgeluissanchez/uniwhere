{
  "expo": {
    "name": "UniWhere",
    "slug": "uniwhere",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "uniwhere",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSCameraUsageDescription": "UniWhere uses the camera for the AR route visualization experience."
      }
    },
    "android": {
      "package": "com.uninorte.uniwhere",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Cal_Sans/CalSans-Regular.ttf",
            "./assets/fonts/ABeeZee/ABeeZee-Regular.ttf",
            "./assets/fonts/ABeeZee/ABeeZee-Italic.ttf"
          ],
          "android": {
            "fonts": [
              {
                "fontFamily": "Cal Sans",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Cal_Sans/CalSans-Regular.ttf",
                    "weight": 400
                  }
                ]
              },
              {
                "fontFamily": "ABeeZee",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/ABeeZee/ABeeZee-Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "./assets/fonts/ABeeZee/ABeeZee-Italic.ttf",
                    "weight": 400,
                    "style": "italic"
                  }
                ]
              }
            ]
          }
        }
      ],
      "expo-image",
      "expo-router",
      "expo-sharing",
      "expo-web-browser",
      "expo-camera"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
